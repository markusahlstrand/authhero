{
  "name": "@authhero/aws-adapter",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "0.38.1",
  "files": [
    "dist"
  ],
  "main": "dist/aws-adapter.cjs",
  "module": "dist/aws-adapter.mjs",
  "types": "dist/aws-adapter.d.ts",
  "exports": {
    ".": {
      "types": "./dist/aws-adapter.d.ts",
      "require": "./dist/aws-adapter.cjs",
      "import": "./dist/aws-adapter.mjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json && rollup -c rollup.dts.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@types/node": "^24.12.4",
    "dynalite": "^3.2.2",
    "hono": "^4.12.23",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.6.8"
  },
  "dependencies": {
    "@authhero/adapter-interfaces": "workspace:*",
    "@authhero/proxy": "workspace:*",
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "nanoid": "^5.1.11"
  }
}
