{
  "name": "@authhero/adapter-interfaces",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "4.0.0",
  "files": [
    "dist"
  ],
  "main": "dist/adapter-interfaces.cjs",
  "module": "dist/adapter-interfaces.mjs",
  "types": "dist/adapter-interfaces.d.ts",
  "exports": {
    ".": {
      "types": "./dist/adapter-interfaces.d.ts",
      "require": "./dist/adapter-interfaces.cjs",
      "import": "./dist/adapter-interfaces.mjs"
    },
    "./sql": {
      "types": "./dist/sql.d.ts",
      "require": "./dist/sql.cjs",
      "import": "./dist/sql.mjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json && rollup -c rollup.dts.config.mjs"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@types/node": "^22.19.19",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.14"
  },
  "peerDependencies": {
    "@hono/zod-openapi": "^1.4.0"
  },
  "dependencies": {
    "nanoid": "^5.1.11"
  }
}
