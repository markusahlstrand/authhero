{
  "name": "@authhero/drizzle",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "0.62.1",
  "files": [
    "dist",
    "src/schema",
    "drizzle",
    "drizzle-control-plane"
  ],
  "main": "dist/drizzle-adapter.cjs",
  "module": "dist/drizzle-adapter.mjs",
  "types": "dist/drizzle-adapter.d.ts",
  "exports": {
    ".": {
      "require": "./dist/drizzle-adapter.cjs",
      "import": "./dist/drizzle-adapter.mjs",
      "types": "./dist/drizzle-adapter.d.ts"
    },
    "./schema/sqlite": {
      "import": "./src/schema/sqlite/index.ts",
      "types": "./src/schema/sqlite/index.ts"
    }
  },
  "scripts": {
    "build": "tsc && vite build",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@authhero/adapter-interfaces": "workspace:*",
    "@authhero/proxy": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.11"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.19.41",
    "better-sqlite3": "^11.10.0",
    "drizzle-kit": "^0.31.4",
    "hono": "^4.12.30",
    "typescript": "^5.5.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "hono": "^4.6.8"
  }
}
