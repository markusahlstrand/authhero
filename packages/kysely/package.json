{
  "name": "@authhero/kysely-adapter",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "11.8.8",
  "files": [
    "dist"
  ],
  "main": "dist/kysely-adapter.cjs",
  "module": "dist/kysely-adapter.mjs",
  "types": "dist/kysely-adapter.d.ts",
  "exports": {
    ".": {
      "require": "./dist/kysely-adapter.cjs",
      "import": "./dist/kysely-adapter.mjs",
      "types": "./dist/kysely-adapter.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.types.json && rollup -c rollup.dts.config.mjs",
    "test": "vitest run",
    "export-sql": "npx tsx scripts/export-sql.ts",
    "export-sql:d1": "npx tsx scripts/export-sql.ts --d1",
    "export-sql:combined": "npx tsx scripts/export-sql.ts --split",
    "export-sql:squash": "npx tsx scripts/export-sql.ts --squash"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@types/node": "^22.19.19",
    "better-sqlite3": "^11.10.0",
    "hono": "^4.12.23",
    "kysely": "^0.29.2",
    "kysely-planetscale": "^1.5.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@authhero/adapter-interfaces": "workspace:*",
    "@authhero/proxy": "workspace:*",
    "nanoid": "^5.1.11"
  },
  "peerDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.6.8",
    "kysely": "^0.29.0",
    "kysely-planetscale": "^1.5.0"
  }
}
