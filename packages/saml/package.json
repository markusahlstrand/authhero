{
  "name": "@authhero/saml",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "0.4.3",
  "files": [
    "dist"
  ],
  "main": "dist/saml.cjs",
  "module": "dist/saml.mjs",
  "types": "dist/saml.d.ts",
  "exports": {
    ".": {
      "require": "./dist/saml.cjs",
      "import": "./dist/saml.mjs",
      "types": "./dist/saml.d.ts"
    },
    "./core": {
      "require": "./dist/core.cjs",
      "import": "./dist/core.mjs",
      "types": "./dist/core.d.ts"
    },
    "./local-signer": {
      "require": "./dist/local-signer.cjs",
      "import": "./dist/local-signer.mjs",
      "types": "./dist/local-signer.d.ts"
    }
  },
  "scripts": {
    "build": "pnpm build:main && pnpm build:core && pnpm build:local && pnpm build:dts",
    "build:main": "vite build --config vite.config.main.ts",
    "build:core": "vite build --config vite.config.core.ts",
    "build:local": "vite build --config vite.config.local.ts",
    "build:dts": "tsc -p tsconfig.types.json && rollup -c rollup.dts.config.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@hono/zod-openapi": "^1.4.0",
    "@types/node": "^22.19.19",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@authhero/adapter-interfaces": "workspace:*",
    "fast-xml-parser": "^4.5.1",
    "nanoid": "^5.1.11"
  },
  "optionalDependencies": {
    "xml-crypto": "^6.1.2"
  },
  "peerDependencies": {
    "@hono/zod-openapi": "^1.4.0"
  }
}
