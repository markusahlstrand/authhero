ine-none focus-visible:ring-2 focus-visible:ring-blue-500 disabled:pointer-events-none disabled:opacity-50 bg-blue-600 text-white hover:bg-blue-700 dark:bg-blue-700 dark:hover:bg-blue-800 h-10 px-4 py-2 w-full" style="background-color:#0066cc;color:#ffffff;border-radius:4px">Send Reset Link</button></form><div class="mt-4 text-center"><a href="/u/login/identifier?state=mock-state" class="text-sm" style="color:#0066cc">Back to Login</a></div></div></div></div>"`;

