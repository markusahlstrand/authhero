{
  "name": "authhero",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "homepage": "https://authhero.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/markusahlstrand/authhero"
  },
  "version": "8.20.0",
  "files": [
    "dist"
  ],
  "main": "dist/authhero.cjs",
  "module": "dist/authhero.mjs",
  "types": "dist/authhero.d.ts",
  "exports": {
    ".": {
      "types": "./dist/authhero.d.ts",
      "require": "./dist/authhero.cjs",
      "import": "./dist/authhero.mjs"
    },
    "./styles": {
      "import": "./dist/tailwind.css",
      "require": "./dist/tailwind.css"
    }
  },
  "scripts": {
    "dev": "bun --watch src/bun.ts",
    "build": "pnpm build:i18n && pnpm build:emails && pnpm build:tailwind && pnpm build:client && tsc -p tsconfig.types.json && vite build && rollup -c rollup.dts.config.mjs && pnpm build:assets",
    "build:i18n": "node scripts/generate-locale-types.js",
    "build:emails": "tsx scripts/build-emails.tsx",
    "build:tailwind": "node build-tailwind.js",
    "build:client": "vite build --mode client && node build-client.js",
    "build:assets": "node build-assets.js",
    "build:vite": "vite build",
    "start": "pnpm build && node dist/index.js",
    "test": "vitest run",
    "pull-translations": "i18nexus pull --path ./src/locales",
    "watch-translations": "i18nexus listen --path ./src/locales",
    "storybook": "pnpm build:tailwind && storybook dev -p 6006",
    "build-storybook": "pnpm build:tailwind && storybook build -o ../../apps/docs/public/storybook"
  },
  "devDependencies": {
    "@ape-egg/tailwind-rows-columns": "^1.0.2",
    "@authhero/kysely-adapter": "workspace:*",
    "@authhero/widget": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.4.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@types/node": "^24.12.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.2",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "10.5.0",
    "better-sqlite3": "^12.4.1",
    "cssnano": "7.1.2",
    "detectincognitojs": "^1.6.2",
    "fast-xml-parser": "^5.3.1",
    "hono": "^4.12.23",
    "i18nexus-cli": "^3.8.2",
    "kysely": "^0.29.2",
    "postcss": "8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup": "^4.54.0",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^10.4.1",
    "tailwindcss": "3.4.18",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@authhero/adapter-interfaces": "workspace:*",
    "@authhero/proxy": "workspace:*",
    "@authhero/saml": "workspace:*",
    "@peculiar/x509": "^1.14.0",
    "@simplewebauthn/server": "^13.0.0",
    "arctic": "3.7.0",
    "bcryptjs": "^3.0.3",
    "classnames": "^2.5.1",
    "cookie": "^1.1.1",
    "country-list": "^2.4.1",
    "i18next": "^25.6.0",
    "libphonenumber-js": "^1.13.3",
    "liquidjs": "^10.27.0",
    "nanoid": "^5.1.11",
    "oslo": "^1.2.1",
    "qrcode": "^1.5.4",
    "sanitize-html": "^2.17.4",
    "xstate": "^5.31.1"
  },
  "peerDependencies": {
    "@authhero/widget": "^0.1.0",
    "@hono/zod-openapi": "^1.4.0",
    "hono": "^4.8.7",
    "ua-parser-js": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependenciesMeta": {
    "@authhero/widget": {
      "optional": true
    },
    "ua-parser-js": {
      "optional": true
    }
  }
}
