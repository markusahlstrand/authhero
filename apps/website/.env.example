# Local website deploy config (copy to .env — .env is git-ignored).
# Wrangler auto-loads these when running `pnpm deploy` from apps/website.

# Which Cloudflare account the local `wrangler pages deploy` targets.
# authhero.net account (where docs.authhero.net lives):
CLOUDFLARE_ACCOUNT_ID=e12057bf51e195d4c54e0152c2bb716d

# Optional: a Pages-scoped API token. If omitted, wrangler falls back to
# its OAuth login (`npx wrangler login`).
# CLOUDFLARE_API_TOKEN=
