{
  "name": "@authhero/docs",
  "private": true,
  "version": "1.59.0",
  "description": "AuthHero documentation site",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build",
    "build:full": "cd ../../packages/authhero && pnpm build-storybook && cd ../../apps/docs && vitepress build",
    "preview": "vitepress preview",
    "deploy": "npx -y wrangler@4 pages deploy .vitepress/dist --project-name=authhero-docs --branch=main",
    "deploy:preview": "npx -y wrangler@4 pages deploy .vitepress/dist --project-name=authhero-docs --branch=preview"
  },
  "devDependencies": {
    "vitepress": "^1.3.4"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "mermaid": "^11.15.0",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
