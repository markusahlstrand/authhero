{
  "name": "authhero-monorepo",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm --recursive --parallel --stream run dev",
    "test": "echo \"Error: no test specified\" && exit 0",
    "format": "prettier --write \"./**/*.{js,jsx,ts,tsx,json}\"",
    "manage": "pnpm --filter @authhero/manage",
    "admin": "pnpm --filter @authhero/admin",
    "authhero": "pnpm --filter authhero",
    "proxy": "pnpm --filter @authhero/proxy",
    "proxy-dev": "pnpm --filter proxy-dev",
    "create-authhero": "pnpm --filter create-authhero",
    "interfaces": "pnpm --filter @authhero/adapter-interfaces",
    "cloudflare": "pnpm --filter @authhero/cloudflare-adapter",
    "aws-adapter": "pnpm --filter @authhero/aws-adapter",
    "drizzle": "pnpm --filter @authhero/drizzle",
    "kysely": "pnpm --filter @authhero/kysely-adapter",
    "demo": "pnpm --filter @authhero/demo",
    "saml": "pnpm --filter @authhero/saml",
    "vitepress": "pnpm --filter @authhero/docs",
    "website": "pnpm --filter @authhero/website",
    "multi-tenancy": "pnpm --filter @authhero/multi-tenancy",
    "widget": "pnpm --filter @authhero/widget",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v && docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "conformance:start": "cd ~/conformance-suite && docker compose -f docker-compose-dev-mac.yml up -d",
    "conformance:stop": "cd ~/conformance-suite && docker compose -f docker-compose-dev-mac.yml down",
    "conformance:run": "pnpm --filter @authhero/conformance-runner exec playwright test",
    "conformance:report": "pnpm --filter @authhero/conformance-runner conformance:report",
    "conformance:seed": "node apps/conformance-runner/scripts/seed.mjs",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.1",
    "eslint": "9.x",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.15",
      "@types/react-dom": "19.2.3"
    }
  }
}
