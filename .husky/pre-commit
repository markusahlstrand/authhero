set -e

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks not found. Install with: brew install gitleaks"
  exit 1
fi
gitleaks protect --staged --verbose --redact

# Build every workspace package in dependency order. pnpm -r resolves the
# topological order from workspace deps, so a package's dist/*.d.ts always
# exist before the next package type-checks against them (the manual ordered
# list this replaced was fragile: e.g. cloudflare built before multi-tenancy).
pnpm -r --filter './packages/**' build

pnpm kysely test
pnpm drizzle test
pnpm saml test
pnpm authhero test
pnpm aws-adapter test
pnpm multi-tenancy test
pnpm cloudflare test
pnpm widget test
pnpm admin test